PROJECT_NAME=UzbekMentorAI
ENVIRONMENT=development

POSTGRES_USER=uzbekmentor
POSTGRES_PASSWORD=uzbekmentor_dev_password
POSTGRES_DB=uzbekmentor
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://uzbekmentor:uzbekmentor_dev_password@db:5432/uzbekmentor

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_API_VERSION=2023-06-01
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1600
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Tashkent
MONTHLY_INGEST_HOUR=3
MONTHLY_INGEST_MINUTE=0
INGEST_BATCH_SIZE=8

VITE_API_BASE_URL=/api
